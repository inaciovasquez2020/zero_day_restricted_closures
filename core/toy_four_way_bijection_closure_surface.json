    "x = (v - V) / (c - V)",
    "R = 1 + x",
    "E = R * N(S)"
  ],
  "inverse_maps": [
    "R = E / N(S)",
    "x = R - 1",
    "v = V + x * (c - V)"
  ],
  "closed_toy_formulae": {
    "elapsed_from_speed": "E = (1 + (v - V) / (c - V)) * N(S)",
    "speed_from_elapsed": "v = V + ((E / N(S)) - 1) * (c - V)"
  },
  "claims": [
