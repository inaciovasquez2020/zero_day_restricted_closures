    "the forward and inverse toy maps recover the toy coordinates exactly",
    "the toy maps are strictly monotone under the stated guards"
  ],
  "non_claims": [
    "does_not_derive_a_non_toy_relative_time_law",
    "does_not_identify_F_toy_with_a_physical_time_dilation_law",
    "does_not_prove_physical_time_dilation",
    "does_not_prove_relativistic_time_dilation",
    "does_not_prove_any_empirical_physics_claim"
  ],
  "missing_object": "derived_non_toy_law_replacing_F_toy_x_eq_1_plus_x",
  "boundary": "not(toy_four_way_bijection_proves_physical_time_dilation)"
}
