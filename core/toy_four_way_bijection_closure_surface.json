{
  "object": "toy_four_way_bijection_closure_surface",
  "status": "algebraic_toy_surface_only",
  "guards": [
    "0 < V",
    "V < c",
    "N(S) > 0"
  ],
  "toy_law": {
    "F_toy": "F_toy(x) := 1 + x",
    "bridge": "RelativeTimeScale_x(S,t,x) = F_toy(x)"
  },
  "coordinates": {
    "v": "(V,c)",
    "x": "(0,1)",
    "R": "(1,2)",
    "E": "(N(S),2N(S))"
  },
